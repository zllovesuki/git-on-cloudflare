{
  "name": "git-on-cloudflare",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "test": "ava",
    "test:workers": "vitest run --config vitest.config.ts",
    "test:auth": "vitest run --config vitest.config.ts test/auth.worker.test.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types --strict-vars false",
    "db:gen": "drizzle-kit generate --config drizzle.config.ts"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.28.0",
    "@cloudflare/vitest-pool-workers": "^0.13.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^5.2.0",
    "ava": "^6.1.2",
    "drizzle-kit": "^0.31.4",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.7.0",
    "typescript": "^5.9.2",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "wrangler": "^4.37.1"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "highlight.js": "^11.11.1",
    "isomorphic-git": "^1.33.1",
    "itty-router": "^5.0.22",
    "lucide-react": "^0.542.0",
    "marked": "^17.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanitize-html": "^2.17.1"
  },
  "ava": {
    "files": [
      "test/**/*.test.ts",
      "!test/**/*.worker.test.ts"
    ],
    "extensions": {
      "ts": "module"
    },
    "nodeArguments": [
      "--import=tsx",
      "--import=./test/register.js"
    ],
    "timeout": "30s"
  }
}
